CXX_STD = CXX17

# enforce compilation of cpp files
PKG_SRC = \
  core/GraphData.cpp \
  core/SCParser.cpp \
  core/GraphHandler.cpp \
  core/Neighborhood.cpp \
  loco_R.cpp

# include directories
